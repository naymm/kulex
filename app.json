{
  "expo": {
    "name": "Kulex",
    "slug": "Kulex",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "myapp",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "splash": {
      "image": "./assets/images/logoblack.png",
      "resizeMode": "contain",
      "backgroundColor": "#FFFFFF"
    },
    "ios": {
      "supportsTablet": true,
      "splash": {
        "image": "./assets/images/logoblack.png",
        "resizeMode": "contain",
        "backgroundColor": "#FFFFFF"
      },
      "bundleIdentifier": "com.kulex.sanep"
    },
    "android": {
      "splash": {
        "image": "./assets/images/logoblack.png",
        "resizeMode": "contain",
        "backgroundColor": "#FFFFFF"
      },
      "package": "com.anonymous.boltexponativewind"
    },
    "web": {
      "bundler": "metro",
      "output": "single",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      [
        "expo-splash-screen",
        {
          "image": "./assets/images/logoblack.png",
          "imageWidth": 220,
          "resizeMode": "contain",
          "backgroundColor": "#FFFFFF"
        }
      ],
      "expo-font",
      "expo-web-browser",
      "expo-sharing",
      "expo-asset"
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
